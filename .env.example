# =====================================================
# Daily Digest - API 密钥配置模板
# =====================================================
# 将此文件复制为 .env，然后填入你的实际密钥
# cp .env.example .env
# =====================================================

# Anthropic API Key
# 获取地址: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# GitHub Personal Access Token (只需 public_repo 权限)
# 获取地址: https://github.com/settings/tokens → Generate new token (classic)
# 勾选: repo (public) 即可
GITHUB_TOKEN=ghp_xxxxxxxxxxxxx

# YouTube Data API v3 Key
# 获取地址: https://console.cloud.google.com → 创建项目 → 启用 YouTube Data API v3 → 创建凭据
YOUTUBE_API_KEY=AIzaSyxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 邮件发送配置（SMTP）
# ─────────────────────────────────────────────
# Gmail 用户：需在 Google 账户开启「两步验证」后生成「应用专用密码」
# 应用专用密码获取：https://myaccount.google.com/apppasswords
# QQ邮箱：SMTP_HOST=smtp.qq.com，SMTP_PASS 填授权码

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# 多个收件人用英文逗号分隔
RECIPIENT_EMAILS=a@example.com,b@example.com
